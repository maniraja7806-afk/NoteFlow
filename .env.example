# ----- Backend (server/.env) -----
# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/noteflow

# Secret used to sign JWT access tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret

# JWT expiry (e.g. 7d, 24h, 3600s)
JWT_EXPIRES_IN=7d

# Port the API/Socket.IO server listens on
PORT=5000

# Allowed origin for CORS + Socket.IO (the frontend URL)
CLIENT_URL=http://localhost:5173

# Node environment
NODE_ENV=development

# ----- Frontend (client/.env) -----
# Base URL of the backend API (used by Vite, must be prefixed with VITE_)
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
